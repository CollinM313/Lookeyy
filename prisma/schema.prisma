generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Auth / Users -----------------------------

enum Role {
  CLIENT
  AGENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  agentProfile AgentProfile?

  listingsAsAgent Listing[] @relation("AgentListings")
  bookingsAsClient Booking[] @relation("ClientBookings")
  bookingsAsAgent  Booking[] @relation("AgentBookings")
  reviewsGiven    Review[]  @relation("ClientReviews")
  favorites       Favorite[]
  notifications   Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------- Agents -----------------------------

enum AgentStatus {
  PENDING
  APPROVED
  REJECTED
}

model AgentProfile {
  id                String      @id @default(cuid())
  userId            String      @unique
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber     String
  brokerage         String
  coverageArea      String
  city              String?
  state             String?
  lat               Float?
  lng               Float?
  bio               String      @db.Text
  photoUrl          String?
  areasOfExpertise  String[]    @default([])
  status            AgentStatus @default(PENDING)
  ratingAvg         Float       @default(0)
  ratingCount       Int         @default(0)
  tourCount         Int         @default(0)
  rejectionReason   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  bookings      Booking[]      @relation("SuggestedAgent")
  availability  Availability[]
  reviews       Review[]
}

model Availability {
  id        String   @id @default(cuid())
  agentId   String
  agent     AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String
  endTime   String
  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([agentId, date])
}

// ----------------------------- Listings -----------------------------

enum PropertyType {
  HOUSE
  CONDO
  TOWNHOUSE
  APARTMENT
  LAND
  MULTI_FAMILY
}

enum ListingStatus {
  AVAILABLE
  PENDING
  SOLD
}

model Listing {
  id           String        @id @default(cuid())
  title        String
  address      String
  city         String
  state        String
  zip          String
  price        Int
  beds         Int
  baths        Float
  sqft         Int
  description  String        @db.Text
  propertyType PropertyType
  status       ListingStatus @default(AVAILABLE)
  lat          Float?
  lng          Float?
  neighborhoodInfo String?   @db.Text
  idxListingKey String?      @unique
  agentId      String?
  agent        User?         @relation("AgentListings", fields: [agentId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  photos    ListingPhoto[]
  bookings  Booking[]
  favorites Favorite[]
}

model ListingPhoto {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

// ----------------------------- Bookings -----------------------------

enum TourType {
  RECORDED
  LIVE
}

enum BookingStatus {
  REQUESTED
  PENDING_ADMIN_APPROVAL
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id               String        @id @default(cuid())
  listingId        String
  listing          Listing       @relation(fields: [listingId], references: [id])
  clientId         String
  client           User          @relation("ClientBookings", fields: [clientId], references: [id])
  agentId          String?
  agent            User?         @relation("AgentBookings", fields: [agentId], references: [id])
  suggestedAgentId String?
  suggestedAgent   AgentProfile? @relation("SuggestedAgent", fields: [suggestedAgentId], references: [id])
  matchRationale   Json?

  tourType        TourType
  status          BookingStatus @default(REQUESTED)
  scheduledAt     DateTime
  contactName     String
  contactPhone    String
  contactEmail    String
  specialRequests String?       @db.Text

  dailyRoomUrl      String?
  recordedVideoUrl  String?
  fallbackPhone     String?

  cancelledAt     DateTime?
  cancelReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review?

  @@index([status])
  @@index([scheduledAt])
}

// ----------------------------- Reviews -----------------------------

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clientId  String
  client    User     @relation("ClientReviews", fields: [clientId], references: [id])
  agentId   String
  agent     AgentProfile @relation(fields: [agentId], references: [id])
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

// ----------------------------- Notifications -----------------------------

enum NotificationType {
  BOOKING_REQUESTED
  BOOKING_PENDING_APPROVAL
  BOOKING_CONFIRMED
  AGENT_ASSIGNED
  TOUR_REMINDER
  TOUR_COMPLETED
  REVIEW_REQUEST
  AGENT_APPLICATION_APPROVED
  AGENT_APPLICATION_REJECTED
  BOOKING_CANCELLED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  payload   Json?
  channel   String           @default("email")
  sentAt    DateTime         @default(now())
}
